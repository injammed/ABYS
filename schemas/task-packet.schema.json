{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/injammed/ABYS/schemas/task-packet.schema.json",
  "title": "ABYS Task Packet",
  "description": "Codex-compatible execution packet for converting an intake concept into repository work, tests, validation, and recursive improvement.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "source_repo",
    "objective",
    "assumptions",
    "routing_decision",
    "files",
    "implementation_steps",
    "validation",
    "risks_blockers",
    "terminal_output",
    "next_recursive_improvement"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^ABYS-TASK-[0-9A-Z_-]+$" },
    "source_repo": { "type": "string", "enum": ["ITEM", "ABYS", "SYNTEL", "external"] },
    "objective": { "type": "string", "minLength": 10 },
    "assumptions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "routing_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["route", "target_repo", "reason", "handoff_required"],
      "properties": {
        "route": { "type": "string", "enum": ["ABYS", "ITEM", "SYNTEL", "split", "hold_for_review"] },
        "target_repo": { "type": "string", "enum": ["ITEM", "ABYS", "SYNTEL"] },
        "handoff_required": { "type": "boolean" },
        "handoff_targets": { "type": "array", "items": { "type": "string", "enum": ["ITEM", "ABYS", "SYNTEL"] }, "uniqueItems": true },
        "reason": { "type": "string", "minLength": 10 }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "action"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "action": { "type": "string", "enum": ["create", "edit", "delete", "move", "review", "test", "document"] },
          "notes": { "type": "string" }
        }
      }
    },
    "implementation_steps": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "validation": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "risks_blockers": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "terminal_output": {
      "type": "string",
      "enum": ["file_edit", "schema", "issue", "test", "workflow", "pull_request", "deployment_step", "docs", "hold", "split_packet", "deletion_candidate"]
    },
    "next_recursive_improvement": { "type": "string", "minLength": 1 },
    "routing_notes": { "type": "string" }
  }
}
