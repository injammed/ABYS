{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/injammed/ABYS/schemas/business-offer.schema.json",
  "title": "ABYS Business Offer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "offer_id",
    "name",
    "buyer_segment",
    "pain",
    "promise",
    "scope",
    "deliverables",
    "pricing",
    "intake_requirements",
    "fulfillment_workflow",
    "payment_flow",
    "success_metrics",
    "retention_loop"
  ],
  "properties": {
    "offer_id": { "type": "string", "pattern": "^ABYS-OFFER-[0-9A-Z_-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "buyer_segment": { "type": "string", "minLength": 1 },
    "pain": { "type": "string", "minLength": 1 },
    "promise": { "type": "string", "minLength": 1 },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["included", "excluded"],
      "properties": {
        "included": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "excluded": { "type": "array", "items": { "type": "string" } }
      }
    },
    "deliverables": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "pricing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "amount", "currency", "payment_terms"],
      "properties": {
        "model": { "type": "string", "enum": ["fixed_fee", "monthly_retainer", "usage_based", "setup_plus_retainer"] },
        "amount": { "type": "number", "minimum": 0 },
        "currency": { "type": "string", "minLength": 3, "maxLength": 8 },
        "payment_terms": { "type": "string", "minLength": 1 }
      }
    },
    "intake_requirements": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "fulfillment_workflow": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "payment_flow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["invoice_required", "payment_status_values"],
      "properties": {
        "invoice_required": { "type": "boolean" },
        "payment_status_values": { "type": "array", "items": { "type": "string", "enum": ["not_invoiced", "invoiced", "deposit_paid", "paid", "overdue", "refunded"] } }
      }
    },
    "success_metrics": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "retention_loop": { "type": "string", "minLength": 1 }
  }
}
