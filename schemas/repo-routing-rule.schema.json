{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/injammed/ABYS/schemas/repo-routing-rule.schema.json",
  "title": "Repository Routing Rule",
  "type": "object",
  "additionalProperties": false,
  "required": ["repo", "role", "allowed_domains", "forbidden_domains", "required_outputs", "handoff_targets"],
  "properties": {
    "repo": { "type": "string", "enum": ["injammed/ITEM", "injammed/ABYS", "injammed/SYNTEL"] },
    "role": { "type": "string", "enum": ["artifact_canon", "execution_machine", "m2m_protocol"] },
    "allowed_domains": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "forbidden_domains": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "required_outputs": { "type": "array", "minItems": 1, "items": { "type": "string", "enum": ["issue", "PR", "schema", "test", "workflow", "docs", "code", "example", "canonical_record", "protocol_spec"] }, "uniqueItems": true },
    "handoff_targets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifact_canon": { "type": "string", "enum": ["injammed/ITEM"] },
        "execution_machine": { "type": "string", "enum": ["injammed/ABYS"] },
        "m2m_protocol": { "type": "string", "enum": ["injammed/SYNTEL"] }
      }
    }
  }
}
